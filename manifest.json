{
  "manifest_version": 3,
  "name": "Kindle Translator Helper",
  "version": "1.0",
  "description": "Extracts text from Kindle Cloud Reader for translation",
  "permissions": ["activeTab", "downloads", "storage", "scripting"],
  "host_permissions": ["https://read.amazon.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://read.amazon.com/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
